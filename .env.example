# Google Ads Dashboard - Configuration

# Clé de chiffrement (générée automatiquement au premier lancement)
# NE PAS PARTAGER cette clé — elle protège vos credentials
ENCRYPTION_KEY=

# Durée du cache (en secondes)
# 3600 = 1 heure (recommandé pour éviter les limites API)
CACHE_DURATION=3600

# Mode debug (affiche plus de logs)
DEBUG=False

# Port de l'application Streamlit
PORT=8501

# Répertoire de stockage des credentials chiffrés
CREDENTIALS_DIR=.credentials

# Répertoire de cache
CACHE_DIR=.cache
